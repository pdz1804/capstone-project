# ── OpenAI / LLM ─────────────────────────────────────────
OPENAI_API_KEY=

# Google Gemini (Lecture Visualization tab + chat infographic tool). Same as frontend GEMINI_API_KEY name.
GEMINI_API_KEY=
# Optional override; default matches Google AI image preview models.
# GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview

# ── Qdrant (see Phase_2_PDZ_003_Test_Qdrant_Cloud) ───────
QDRANT_MODE=docker
QDRANT_HOST=localhost
QDRANT_PORT=6333
# Cloud:
# QDRANT_MODE=cloud
# QDRANT_URL=https://xxxx.cloud.qdrant.io:6333
# QDRANT_API_KEY=

# Optional overrides
# QDRANT_TEXT_COLLECTION=edu_text_chunks
# QDRANT_IMAGE_COLLECTION=edu_image_pages
# GET /api/status caches Qdrant collection info to avoid hammering the API (default 20s). Set 0 to disable.
# STATUS_QDRANT_CACHE_TTL_SECONDS=20

# ── ColQwen inference: local GPU vs SageMaker ────────────
# When true, embeddings use AWS SageMaker Runtime (Phase_2_PDZ_002_Model_Deploy).
USE_AWS_SAGEMAKER_INFERENCE=false
AWS_REGION=us-west-2
SAGEMAKER_ENDPOINT_NAME=phase2-colqwen-rt

# ── File storage: local disk vs S3 ───────────────────────
# local (default): uploads and processing under backend/input and backend/output.
# s3: objects live in S3 only; the API syncs to a per-user temp workspace under the OS temp
#     dir (see LOCAL_WORKSPACE_ROOT) for Docling — not under backend/input or backend/output.
# s3 (single bucket): S3_BUCKET + default prefixes input/ and processing/
# s3 (two buckets): S3_ORIGINALS_BUCKET + S3_PROCESSED_BUCKET (prefixes default to "" = bucket root)
FILE_STORAGE_BACKEND=local
# FILE_STORAGE_BACKEND=s3
# S3_ORIGINALS_BUCKET=ai-service-originals-dev
# S3_PROCESSED_BUCKET=ai-service-processed-dev
# Optional explicit prefixes (empty string = objects at bucket root for dual-bucket mode)
# S3_INPUT_PREFIX=
# S3_PROCESSING_PREFIX=
# Per-user S3 layout: users/{sanitized-id}/ under the prefixes above (default on). Set false for one shared prefix.
# S3_USER_ISOLATION=true
# API clients send the logical user as header X-User-Id (defaults to DEFAULT_STORAGE_USER_ID or "default").
# DEFAULT_STORAGE_USER_ID=default
# Override temp root for S3 local sync (default: system temp)
# LOCAL_WORKSPACE_ROOT=
# Optional: separate Qdrant collections per user (same name + suffix). Default false — enable for strict vector isolation.
# QDRANT_ISOLATE_BY_USER=false
# Legacy single-bucket mode:
# S3_BUCKET=your-bucket-name
# S3_INPUT_PREFIX=input/
# S3_PROCESSING_PREFIX=processing/
# AWS credentials: standard boto3 chain (env keys, ~/.aws/credentials, IAM role, etc.)
# Smoke test: python scripts/s3_storage_smoke_test.py

# ── Merge: Firebase Google sign-in + DynamoDB users ─────
# Place your Firebase Admin JSON next to the backend or set path:
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json
# DynamoDB table: partition key uid (String), attributes: email, displayName, role, photoURL, createdAt, lastLogin
DYNAMODB_USERS_TABLE=
# Quiz results table: PK user_id (String), SK attempt_id (String)
DYNAMODB_QUIZ_RESULTS_TABLE=
# Chat sessions/messages tables:
# DYNAMODB_CHATBOT_SESSIONS_TABLE=chatbot-session
# DYNAMODB_CHATBOT_MESSAGES_TABLE=chatbot-messages
# (Chat infographic reload: message items may include an "attachments" list with rel_path;
#  PNG bytes live in S3 processed bucket when FILE_STORAGE_BACKEND=s3 — same vars as pipeline,
#  under .../chat_attachments/... — no extra buckets or Dynamo tables.)
# Feedback table: PK user_id (String), SK feedback_id (String)
DYNAMODB_FEEDBACK_TABLE=
# App usage table (invocation telemetry): PK usage_id (String)
DYNAMODB_APP_USAGE_TABLE=
# Async indexing job persistence table: PK job_id (String)
# Defaults to bk_mind_app_jobs when unset.
DYNAMODB_JOBS_TABLE=bk_mind_app_jobs
# Optional: S3 daily AWS cost CSV source for /api/admin/costs and cost subtab
# Example bucket: bkmind-learning-platform-cost-bucket
# CSV key format under prefix: YYYY-MM-DD-usage-breakdown.csv
AWS_COST_REPORT_S3_BUCKET=
AWS_COST_REPORT_S3_PREFIX=detailed/
# Knowledge registry table (admin CRUD): PK knowledge_id (String)
DYNAMODB_KNOWLEDGE_TABLE=

# Default local admin bootstrap
ENABLE_DEFAULT_ADMIN_BOOTSTRAP=false
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_EMAIL=admin@local.dev
# SECURITY: Generate a strong random password during deployment. Never commit passwords to version control.
# DEFAULT_ADMIN_PASSWORD=

# ── Merge: Amazon Bedrock (generation.provider=bedrock) ─
# Uses default AWS credential chain; model ID in config/default.yaml (Claude Haiku 4.5 multimodal).
AWS_REGION=us-west-2
# Optional overrides (also see config/default.yaml generation.*)
# GENERATION_PROVIDER=bedrock
# GENERATION_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0
# BEDROCK_REGION=us-west-2
# Feedback classifier model (non-blocking background classification)
# FEEDBACK_CLASSIFIER_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0

# ── Merge: SageMaker Docling (Stage 3, separate from ColQwen endpoint) ─
# USE_AWS_SAGEMAKER_DOCLING=false
# SAGEMAKER_DOCLING_ENDPOINT_NAME=phase2-docling-rt

# ── Search cache retry/backoff (avoid per-request timeout stalls when Redis is unreachable) ─
# SEARCH_CACHE_REDIS_RETRY_COOLDOWN_SECONDS=30
# Redis marker TTL for Qdrant setup cache (shared across workers/instances)
# SEARCH_CACHE_QDRANT_SETUP_TTL_SECONDS=3600
# If using ElastiCache Serverless private VPC endpoint, keep SEARCH_CACHE_REDIS_URL on localhost for local dev.
# Set this true only when you intentionally want to try private endpoint connection outside AWS runtime.
# SEARCH_CACHE_ALLOW_PRIVATE_ENDPOINT_LOCAL=false

# ── Office to PDF Conversion (Lambda LibreOffice) ────────
# Lambda function name for office document to PDF conversion (DOCX, PPTX, XLSX, HTML → PDF)
# OFFICE_PDF_LAMBDA_FUNCTION_NAME=office-to-pdf-converter
# OFFICE_PDF_LAMBDA_REGION=us-east-1
# Converter mode: "auto" (Lambda in cloud, local LibreOffice in dev), "local" (always local), or "lambda" (always Lambda)
# OFFICE_PDF_CONVERTER_MODE=auto
