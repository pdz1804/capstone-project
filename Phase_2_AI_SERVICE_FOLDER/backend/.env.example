# ── OpenAI / LLM ─────────────────────────────────────────
OPENAI_API_KEY=

# ── Qdrant (see Phase_2_PDZ_003_Test_Qdrant_Cloud) ───────
QDRANT_MODE=docker
QDRANT_HOST=localhost
QDRANT_PORT=6333
# Cloud:
# QDRANT_MODE=cloud
# QDRANT_URL=https://xxxx.cloud.qdrant.io:6333
# QDRANT_API_KEY=

# Optional overrides
# QDRANT_TEXT_COLLECTION=edu_text_chunks
# QDRANT_IMAGE_COLLECTION=edu_image_pages
# GET /api/status caches Qdrant collection info to avoid hammering the API (default 20s). Set 0 to disable.
# STATUS_QDRANT_CACHE_TTL_SECONDS=20

# ── ColQwen inference: local GPU vs SageMaker ────────────
# When true, embeddings use AWS SageMaker Runtime (Phase_2_PDZ_002_Model_Deploy).
USE_AWS_SAGEMAKER_INFERENCE=false
AWS_REGION=us-west-2
SAGEMAKER_ENDPOINT_NAME=phase2-colqwen-rt

# ── File storage: local disk vs S3 ───────────────────────
# local (default): uploads and processing under backend/input and backend/output.
# s3: objects live in S3 only; the API syncs to a per-user temp workspace under the OS temp
#     dir (see LOCAL_WORKSPACE_ROOT) for Docling — not under backend/input or backend/output.
# s3 (single bucket): S3_BUCKET + default prefixes input/ and processing/
# s3 (two buckets): S3_ORIGINALS_BUCKET + S3_PROCESSED_BUCKET (prefixes default to "" = bucket root)
FILE_STORAGE_BACKEND=local
# FILE_STORAGE_BACKEND=s3
# S3_ORIGINALS_BUCKET=ai-service-originals-dev
# S3_PROCESSED_BUCKET=ai-service-processed-dev
# Optional explicit prefixes (empty string = objects at bucket root for dual-bucket mode)
# S3_INPUT_PREFIX=
# S3_PROCESSING_PREFIX=
# Per-user S3 layout: users/{sanitized-id}/ under the prefixes above (default on). Set false for one shared prefix.
# S3_USER_ISOLATION=true
# API clients send the logical user as header X-User-Id (defaults to DEFAULT_STORAGE_USER_ID or "default").
# DEFAULT_STORAGE_USER_ID=default
# Override temp root for S3 local sync (default: system temp)
# LOCAL_WORKSPACE_ROOT=
# Optional: separate Qdrant collections per user (same name + suffix). Default false — enable for strict vector isolation.
# QDRANT_ISOLATE_BY_USER=false
# Legacy single-bucket mode:
# S3_BUCKET=your-bucket-name
# S3_INPUT_PREFIX=input/
# S3_PROCESSING_PREFIX=processing/
# AWS credentials: standard boto3 chain (env keys, ~/.aws/credentials, IAM role, etc.)
# Smoke test: python scripts/s3_storage_smoke_test.py
