# Leave unset for dev: browser calls `/api/...` and Vite proxies to the backend (vite.config.js).
# Or set explicitly:
# VITE_API_URL=/api
# If the UI is served separately and talks to the API host directly (no /api proxy), use the
# origin only   `/api` is appended automatically:
# VITE_API_URL=http://127.0.0.1:8000