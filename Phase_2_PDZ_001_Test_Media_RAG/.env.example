# ============================================================================
# ENVIRONMENT VARIABLES FOR VIDEO RAG PIPELINE
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env  (Linux/Mac)
#   copy .env.example .env  (Windows)
#
# IMPORTANT: Install python-dotenv first if you haven't:
#   pip install python-dotenv

# ============================================================================
# OPENAI API CONFIGURATION
# ============================================================================
# Required for LLM-based chunk descriptions (Step 5 of pipeline)
# Get your API key from: https://platform.openai.com/api-keys
# 
# NOTE: If not set, pipeline will skip LLM description generation but
# will still complete media processing (Steps 1-4) and RAG indexing (Step 6).
OPENAI_API_KEY=sk-your-api-key-here

# ============================================================================
# PIPELINE BEHAVIOR
# ============================================================================
# The pipeline consists of 7 steps:
# 1. Audio extraction + noise reduction
# 2. Whisper transcription with word timestamps
# 3. Token-aware chunking
# 4. Frame extraction + deduplication
# 5. LLM chunk description generation (requires OPENAI_API_KEY) ← OPTIONAL
# 6. RAG indexing (always runs if chunks exist)
# 7. Semantic search capability (always available if indexed)
#
# Steps 1-4, 6-7 will run even without OPENAI_API_KEY
# Step 5 will be skipped gracefully if API key is missing

# ============================================================================
# OPTIONAL CONFIGURATIONS
# ============================================================================
# Uncomment and customize as needed

# Output directory for processed videos
# OUTPUT_DIR=./output

# Maximum tokens per chunk (default: 100)
# MAX_CHUNK_TOKENS=100

# Frame extraction FPS (default: 1 frame per second)
# FRAME_EXTRACTION_FPS=1.0

# Whisper model size (tiny, base, small, medium, large)
# WHISPER_MODEL=base

# ============================================================================
# EXAMPLE USAGE
# ============================================================================
# 1. Copy this file:
#    cp .env.example .env
#
# 2. Add your OpenAI API key (optional but recommended for full pipeline):
#    OPENAI_API_KEY=sk-proj-abc123...
#
# 3. Run the pipeline:
#    python run_full_pipeline.py
#    OR
#    streamlit run streamlit_app.py
#
# ============================================================================
