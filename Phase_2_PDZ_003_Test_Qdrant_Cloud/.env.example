# ============================================================
# Qdrant + ColPali Configuration
# ============================================================
#
# HOW TO USE:
#   1. Copy this file:   copy .env.example .env
#   2. Choose a mode:    QDRANT_MODE=docker  OR  QDRANT_MODE=cloud
#   3. Fill in the values for THAT mode only (the other block can stay as-is)
#   4. NEVER commit .env to git   add it to .gitignore!
# ============================================================


# ============================================================
# STEP 1   CHOOSE YOUR MODE
# ============================================================
#
#   docker  → Qdrant running locally via Docker (no API key needed)
#   cloud   → Qdrant Cloud managed service (requires URL + API key)
#
QDRANT_MODE=docker


# ============================================================
# DOCKER MODE  (active when QDRANT_MODE=docker)
# ============================================================
#
# Run Qdrant locally with:
#   docker run -p 6333:6333 -p 6334:6334 qdrant/qdrant:latest
#
# Ports:
#   6333 → REST API  (used by qdrant-client Python SDK)
#   6334 → gRPC API  (optional, for high-throughput applications)
#
# Dashboard (Web UI) once the container is running:
#   http://localhost:6333/dashboard
#
QDRANT_HOST=localhost
QDRANT_PORT=6333


# ============================================================
# CLOUD MODE  (active when QDRANT_MODE=cloud)
# ============================================================
#
# WHERE TO GET THESE VALUES:
#   1. Sign up at https://cloud.qdrant.io/  (free tier available)
#   2. Create a cluster → copy the Cluster URL
#   3. Go to API Keys → generate a key and copy it here
#
# Format: https://<cluster-id>.<region>.cloud.qdrant.io:6333
QDRANT_URL=https://your-cluster-id.us-east4-0.gcp.cloud.qdrant.io:6333

# Secret API key   never share or commit this!
QDRANT_API_KEY=your-api-key-here


# ============================================================
# SHARED SETTINGS (apply to both Docker and Cloud modes)
# ============================================================

# Name of the Qdrant collection to create/use
# Think of it like a "table" in SQL   created automatically if it doesn't exist
COLLECTION_NAME=colpali_images_test


# ============================================================
# ColQwen Model Settings (same as Phase_2)
# ============================================================

# HuggingFace model ID
# Options:
#   vidore/colqwen2-v1.0   → ColQwen2  (stable, works with colpali-engine 0.3.x)
#   vidore/colqwen2.5-v0.2 → ColQwen2.5 (needs colpali-engine >= 0.4.0)
COLQWEN_MODEL=vidore/colqwen2-v1.0


# ============================================================
# INFERENCE MODE  (where ColQwen2 runs)
# ============================================================
#
# "local"  → load the model on THIS machine (requires a local GPU with ~8 GB VRAM)
#            02_embed_and_store.py and 03_search_retrieve.py will load ColQwen2 at startup.
#
# "remote" → the model lives on a separate GPU server (e.g. AWS EC2 g4dn.xlarge)
#            Scripts will send HTTP POST requests to INFERENCE_URL instead.
#            The remote server must expose:
#              POST /embed/image  { "image_base64": "..." }  → { "embedding": [[...], ...] }
#              POST /embed/query  { "query_text":   "..." }  → { "embedding": [[...], ...] }
#
# Set to "remote" when:
#  - Your local machine has no GPU
#  - You want to share one GPU server among multiple team members
#  - You are running the application container on ECS without a GPU instance
#
INFERENCE_MODE=local

# Base URL of the remote inference server (only used when INFERENCE_MODE=remote)
# Example: http://10.0.0.5:8080  (private IP of the GPU EC2 instance in the same VPC)
#          http://my-gpu-server.example.com:8080
INFERENCE_URL=http://localhost:8080

